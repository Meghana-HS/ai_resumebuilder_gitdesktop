# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://containers-us-west-xxx.railway.app:7913/railway
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=yourSecretKeyHere123456789012345678901234567890
JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000

# Server Configuration
SERVER_PORT=8081
